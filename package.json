{
  "name": "poker",
  "version": "1.0.0",
  "description": "A modern, minimal poker experience",
  "main": "index.ts",
  "scripts": {
    "dev": "bun --hot ./index.ts",
    "build": "bun build ./frontend/app.tsx --outdir=dist --target=browser --format=esm",
    "vercel-build": "bun install && bun run build",
    "start": "bun ./index.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vercel/node": "^5.7.13",
    "bun-types": "latest"
  }
}
